<Window x:Class="Fylo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Fylo.Converters"
        Title="Fylo"
        Height="640" Width="960"
        MinHeight="400" MinWidth="600"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:IsDirectoryToIconConverter x:Key="IsDirectoryToIconConverter"/>
        <conv:IsEditingConverter x:Key="IsEditingConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>      <!-- Таб-бар (Chrome-стиль) -->
            <RowDefinition Height="Auto"/>    <!-- Тулбар + адресная строка -->
            <RowDefinition Height="*"/>       <!-- Список файлов -->
            <RowDefinition Height="Auto"/>    <!-- Статус-бар -->
        </Grid.RowDefinitions>

        <!-- ================= ТАБ-БАР (Chrome-стиль) ================= -->
        <Border x:Name="TabBar" Grid.Row="0"
                Style="{StaticResource TabBarStyle}"
                MouseLeftButtonDown="TabBar_MouseLeftButtonDown"
                MouseMove="TabBar_MouseMove"
                MouseLeftButtonUp="TabBar_MouseLeftButtonUp"
                MouseRightButtonUp="TabBar_MouseRightButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка приложения -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="12,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F4C1;" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Список вкладок -->
                <ScrollViewer Grid.Column="1"
                              x:Name="TabScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0"
                              Height="36"
                              Focusable="False"
                              Padding="0">
                    <StackPanel Orientation="Horizontal" Height="36">
                        <ItemsControl x:Name="TabItemsControl"
                                      ItemsSource="{Binding Tabs}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TabBorder"
                                            Style="{StaticResource TabItemStyle}"
                                            MouseDown="TabItem_MouseDown"
                                            MouseMove="TabItem_MouseMove"
                                            MouseUp="TabItem_MouseUp"
                                            MouseEnter="TabItem_MouseEnter"
                                            MouseLeave="TabItem_MouseLeave">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       Style="{StaticResource TabTitleTextStyle}"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource TabCloseButtonStyle}"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Кнопка новой вкладки -->
                        <Button Style="{StaticResource NewTabButtonStyle}"
                                Command="{Binding AddTabCommand}"
                                VerticalAlignment="Center"
                                Margin="2,0,4,0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки управления окном -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowButtonBaseStyle}"
                            ToolTip="Свернуть"
                            Click="MinimizeButton_Click">
                        <Viewbox Width="10" Height="10">
                            <Rectangle Width="10" Height="1" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource WindowButtonBaseStyle}"
                            ToolTip="Развернуть"
                            Click="MaximizeButton_Click">
                        <Grid>
                            <Rectangle x:Name="MaximizeIcon" Width="10" Height="10"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1"/>
                            <Rectangle x:Name="RestoreIcon" Width="7" Height="7"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1"
                                       Visibility="Collapsed">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform X="-2" Y="-2"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            ToolTip="Закрыть"
                            Click="CloseButton_Click">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= ВЕРХНЯЯ ПАНЕЛЬ ================= -->
        <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical" Margin="8,6,8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="TogglePanelButton" ToolTip="{Binding DrivePanelToggleTooltip}" Width="36" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding ToggleDrivePanelCommand}">
                            <Grid x:Name="ToggleIconGrid" Width="20" Height="20" UseLayoutRounding="True">
                                <Grid x:Name="HidePanelIcon" Width="20" Height="20">
                                    <Path Fill="#80FFFFFF" Stroke="White" StrokeThickness="1.5" StrokeLineJoin="Round"
                                          Data="M 4,1 A 3,3 0 0,0 1,4 L 1,16 A 3,3 0 0,0 4,19 L 10,19 L 10,1 Z"/>
                                    <Path Stroke="White" StrokeThickness="1.5" StrokeLineJoin="Round"
                                          Data="M 4,1 L 16,1 A 3,3 0 0,1 19,4 L 19,16 A 3,3 0 0,1 16,19 L 4,19 A 3,3 0 0,1 1,16 L 1,4 A 3,3 0 0,1 4,1 Z M 10,1 L 10,19"/>
                                </Grid>
                                <Path x:Name="ShowPanelIcon" Stroke="White" StrokeThickness="1.5" StrokeLineJoin="Round"
                                      Data="M 4,1 L 16,1 A 3,3 0 0,1 19,4 L 19,16 A 3,3 0 0,1 16,19 L 4,19 A 3,3 0 0,1 1,16 L 1,4 A 3,3 0 0,1 4,1 Z M 10,1 L 10,19"/>
                            </Grid>
                        </Button>
                        <Button Content="&#x2190;" ToolTip="Назад" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateBackCommand}"/>
                        <Button Content="&#x2192;" ToolTip="Вперёд" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateForwardCommand}"/>
                        <Button Content="&#x2191;" ToolTip="Вверх" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateUpCommand}"/>
                        <Button Content="&#x21BB;" ToolTip="Обновить (F5)" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Margin="8,0,0,0"
                             Style="{StaticResource AddressBarStyle}"
                             Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             Height="30">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding GoToAddressCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Border Grid.Column="2" Width="8"/>

                    <Border Grid.Column="3" Style="{StaticResource SearchBoxContainerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource ScopeToggleButtonStyle}"
                                    Content="{Binding SearchScopeIcon}"
                                    Command="{Binding ToggleSearchScopeCommand}"
                                    ToolTip="{Binding SearchScopeTooltip}"/>

                            <TextBlock Grid.Column="1" Text="&#x1F50D;" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="2,0,4,0"/>

                            <TextBox x:Name="SearchBox" Grid.Column="2"
                                     Style="{StaticResource SearchInputStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="SearchBox_KeyDown"
                                     ToolTip="Поиск по имени файла (Ctrl+F)">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="3"
                                    Style="{StaticResource ClearSearchButtonStyle}"
                                    Command="{Binding ClearSearchCommand}"
                                    Visibility="{Binding IsSearchActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                    ToolTip="Очистить поиск"
                                    Content="&#x2715;"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================= ОСНОВНАЯ ОБЛАСТЬ: БОКОВАЯ ПАНЕЛЬ + СПИСОК ================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="200" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Боковая панель: дерево ===== -->
            <Border x:Name="LeftPanelBorder" Grid.Column="0" Width="200" MinWidth="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Border.Resources>
                    <conv:SidebarTreeTemplateSelector x:Key="SidebarTemplateSelector"
                        SectionTemplate="{StaticResource SidebarSectionTemplate}"
                        ThisPcTemplate="{StaticResource SidebarThisPcTemplate}"
                        DriveTemplate="{StaticResource SidebarDriveTemplate}"
                        FolderTemplate="{StaticResource SidebarFolderTemplate}"
                        RecycleBinTemplate="{StaticResource SidebarRecycleBinTemplate}"/>
                </Border.Resources>

                <TreeView x:Name="SidebarTree"
                          Background="Transparent"
                          BorderThickness="0"
                          ItemsSource="{Binding SidebarItems}"
                          ItemTemplateSelector="{StaticResource SidebarTemplateSelector}"
                          ItemContainerStyle="{StaticResource SidebarTreeItemStyle}"
                          SelectedItemChanged="SidebarTree_SelectedItemChanged"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- ===== Список файлов ===== -->
            <Grid Grid.Column="2">
            <ListView x:Name="FilesListView"
                      Background="{StaticResource AppBackgroundBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderThickness="0"
                      ItemsSource="{Binding EntriesView}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionMode="Extended"
                      AlternationCount="2"
                      ContextMenuOpening="FilesListView_ContextMenuOpening"
                      PreviewMouseWheel="FilesListView_PreviewMouseWheel"
                      SelectionChanged="FilesListView_SelectionChanged">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Создать папку" Command="{Binding CreateFolderCommand}"
                                  Visibility="{Binding IsShowingRecycleBin, Converter={x:Static conv:InvertedBoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Создать файл" Command="{Binding CreateFileCommand}"
                                  Visibility="{Binding IsShowingRecycleBin, Converter={x:Static conv:InvertedBoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Восстановить" Command="{Binding RestoreRecycleBinEntryCommand}"
                                  Visibility="{Binding IsShowingRecycleBin, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Переименовать" Command="{Binding RenameEntryCommand}"
                                  Visibility="{Binding IsShowingRecycleBin, Converter={x:Static conv:InvertedBoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Удалить" Command="{Binding DeleteEntryCommand}"/>
                        <MenuItem Header="Очистить корзину" Command="{Binding EmptyRecycleBinCommand}"
                                  Visibility="{Binding IsShowingRecycleBin, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Добавить в избранное"
                                  Command="{Binding AddToFavoritesCommand}"
                                  Visibility="{Binding CanAddToFavorites, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                        <MenuItem Header="Открыть расположение"
                                  Command="{Binding OpenFileLocationCommand}"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="rowBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <GridViewRowPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                        <EventSetter Event="KeyDown" Handler="ListViewItem_KeyDown"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="34">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsDirectory, Converter={StaticResource IsDirectoryToIconConverter}}"
                                               FontSize="14" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="380">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Имя" Tag="Name"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel.Visibility>
                                                <MultiBinding Converter="{StaticResource IsEditingConverter}"
                                                              ConverterParameter="Invert">
                                                    <Binding Path="FullPath"/>
                                                    <Binding Path="DataContext.EditingEntryFullPath"
                                                             RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                                </MultiBinding>
                                            </StackPanel.Visibility>
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding RelativePath}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasRelativePath, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                        </StackPanel>
                                        <TextBox x:Name="RenameTextBox"
                                                 Text="{Binding DataContext.PendingRenameText, RelativeSource={RelativeSource AncestorType=ListView}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"
                                                 Background="{StaticResource PanelBackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="2,1"
                                                 CaretBrush="{StaticResource TextPrimaryBrush}"
                                                 LostFocus="RenameTextBox_LostFocus">
                                            <TextBox.Visibility>
                                                <MultiBinding Converter="{StaticResource IsEditingConverter}">
                                                    <Binding Path="FullPath"/>
                                                    <Binding Path="DataContext.EditingEntryFullPath"
                                                             RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                                </MultiBinding>
                                            </TextBox.Visibility>
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return"
                                                            Command="{Binding DataContext.CommitRenameCommand, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                <KeyBinding Key="Escape"
                                                            Command="{Binding DataContext.CancelRenameCommand, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="180">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Дата изменения" Tag="Modified"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Modified, StringFormat='dd.MM.yyyy HH:mm'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="160">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Тип" Tag="TypeDisplay"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TypeDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="110">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Размер" Tag="SizeBytes"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Подсказка во время поиска -->
            <TextBlock Text="Поиск..."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Visibility="{Binding IsSearching, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

            <!-- Подсказка при пустом результате поиска -->
            <TextBlock Text="No results found"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Visibility="{Binding IsSearchEmpty, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

            </Grid>
        </Grid>

        <!-- ================= СТАТУС-БАР ================= -->
        <Border Grid.Row="3" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="10,5" FontSize="12"/>
        </Border>

    </Grid>
</Window>
