<Window x:Class="FastExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FastExplorer.Converters"
        Title="Fast Explorer"
        Height="640" Width="960"
        MinHeight="400" MinWidth="600"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:IsDirectoryToIconConverter x:Key="IsDirectoryToIconConverter"/>
        <conv:IsEditingConverter x:Key="IsEditingConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>      <!-- Кастомный заголовок -->
            <RowDefinition Height="Auto"/>    <!-- Тулбар + адресная строка -->
            <RowDefinition Height="*"/>       <!-- Список файлов -->
            <RowDefinition Height="Auto"/>    <!-- Статус-бар -->
        </Grid.RowDefinitions>

        <!-- ================= КАСТОМНЫЙ ЗАГОЛОВОК (стиль Discord) ================= -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                MouseMove="TitleBar_MouseMove"
                MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                MouseRightButtonUp="TitleBar_MouseRightButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка приложения + название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0">
                    <TextBlock Text="&#x1F4C1;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Fast Explorer"
                               Style="{StaticResource WindowTitleTextStyle}"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Заглушка для перетаскивания -->
                <Grid Grid.Column="1" Background="Transparent"/>

                <!-- Кнопки управления окном -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowButtonBaseStyle}"
                            ToolTip="Свернуть"
                            Click="MinimizeButton_Click">
                        <Viewbox Width="10" Height="10">
                            <Rectangle Width="10" Height="1" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource WindowButtonBaseStyle}"
                            ToolTip="Развернуть"
                            Click="MaximizeButton_Click">
                        <Grid>
                            <Rectangle x:Name="MaximizeIcon" Width="10" Height="10"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1"/>
                            <Rectangle x:Name="RestoreIcon" Width="7" Height="7"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1"
                                       Visibility="Collapsed">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform X="-2" Y="-2"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            ToolTip="Закрыть"
                            Click="CloseButton_Click">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= ВЕРХНЯЯ ПАНЕЛЬ ================= -->
        <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical" Margin="8,6,8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="&#x2190;" ToolTip="Назад" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateBackCommand}"/>
                        <Button Content="&#x2192;" ToolTip="Вперёд" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateForwardCommand}"/>
                        <Button Content="&#x2191;" ToolTip="Вверх" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding NavigateUpCommand}"/>
                        <Button Content="&#x21BB;" ToolTip="Обновить (F5)" Width="32" Height="30"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Margin="8,0,0,0"
                             Style="{StaticResource AddressBarStyle}"
                             Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             Height="30">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding GoToAddressCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Border Grid.Column="2" Width="8"/>

                    <Border Grid.Column="3" Style="{StaticResource SearchBoxContainerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource ScopeToggleButtonStyle}"
                                    Content="{Binding SearchScopeIcon}"
                                    Command="{Binding ToggleSearchScopeCommand}"
                                    ToolTip="{Binding SearchScopeTooltip}"/>

                            <TextBlock Grid.Column="1" Text="&#x1F50D;" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="2,0,4,0"/>

                            <TextBox x:Name="SearchBox" Grid.Column="2"
                                     Style="{StaticResource SearchInputStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="SearchBox_KeyDown"
                                     ToolTip="Поиск по имени файла (Ctrl+F)">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="3"
                                    Style="{StaticResource ClearSearchButtonStyle}"
                                    Command="{Binding ClearSearchCommand}"
                                    Visibility="{Binding IsSearchActive, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"
                                    ToolTip="Очистить поиск"
                                    Content="&#x2715;"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================= ОСНОВНАЯ ОБЛАСТЬ: БОКОВАЯ ПАНЕЛЬ + СПИСОК ================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140" MaxWidth="360"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Боковая панель: диски ===== -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ЭТОТ КОМПЬЮТЕР"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="14,12,10,6"/>

                    <ListView DockPanel.Dock="Top"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding Drives}"
                              ItemContainerStyle="{StaticResource DriveListItemStyle}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Cursor="Hand"
                                            MouseLeftButtonUp="DriveItem_MouseLeftButtonUp">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F4BE;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="13">
                                                <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                                <Run Text=" (" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="{Binding DriveLetter, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text=")" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding CapacityDisplay}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Мини-полоса заполненности диска -->
                                    <Grid Height="4" Margin="22,6,4,0">
                                        <Border Background="{StaticResource BorderBrush}" CornerRadius="2"/>
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="2"
                                                HorizontalAlignment="Stretch"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleY="1" ScaleX="{Binding UsedFraction}"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- ===== Разделитель для изменения ширины панели ===== -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"/>

            <!-- ===== Список файлов ===== -->
            <Grid Grid.Column="2">
            <ListView x:Name="FilesListView"
                      Background="{StaticResource AppBackgroundBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderThickness="0"
                      ItemsSource="{Binding EntriesView}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      ScrollViewer.CanContentScroll="True"
                      SelectionMode="Extended"
                      AlternationCount="2"
                      ContextMenuOpening="FilesListView_ContextMenuOpening">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Создать папку" Command="{Binding CreateFolderCommand}"/>
                        <MenuItem Header="Создать файл" Command="{Binding CreateFileCommand}"/>
                        <Separator/>
                        <MenuItem Header="Переименовать" Command="{Binding RenameEntryCommand}"/>
                        <MenuItem Header="Удалить" Command="{Binding DeleteEntryCommand}"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="rowBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <GridViewRowPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                        <EventSetter Event="KeyDown" Handler="ListViewItem_KeyDown"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="34">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsDirectory, Converter={StaticResource IsDirectoryToIconConverter}}"
                                               FontSize="14" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="380">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Имя" Tag="Name"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel.Visibility>
                                                <MultiBinding Converter="{StaticResource IsEditingConverter}"
                                                              ConverterParameter="Invert">
                                                    <Binding Path="FullPath"/>
                                                    <Binding Path="DataContext.EditingEntryFullPath"
                                                             RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                                </MultiBinding>
                                            </StackPanel.Visibility>
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding RelativePath}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasRelativePath, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>
                                        </StackPanel>
                                        <TextBox x:Name="RenameTextBox"
                                                 Text="{Binding DataContext.PendingRenameText, RelativeSource={RelativeSource AncestorType=ListView}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"
                                                 Background="{StaticResource PanelBackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="2,1"
                                                 CaretBrush="{StaticResource TextPrimaryBrush}"
                                                 LostFocus="RenameTextBox_LostFocus">
                                            <TextBox.Visibility>
                                                <MultiBinding Converter="{StaticResource IsEditingConverter}">
                                                    <Binding Path="FullPath"/>
                                                    <Binding Path="DataContext.EditingEntryFullPath"
                                                             RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                                </MultiBinding>
                                            </TextBox.Visibility>
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return"
                                                            Command="{Binding DataContext.CommitRenameCommand, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                <KeyBinding Key="Escape"
                                                            Command="{Binding DataContext.CancelRenameCommand, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="180">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Дата изменения" Tag="Modified"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Modified, StringFormat='dd.MM.yyyy HH:mm'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="160">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Тип" Tag="TypeDisplay"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TypeDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="110">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Размер" Tag="SizeBytes"
                                                       Click="GridViewColumnHeader_Click"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Подсказка при пустом результате поиска -->
            <TextBlock Text="No results found"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Visibility="{Binding IsSearchEmpty, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}"/>

            <!-- Индикатор загрузки поверх списка -->
            <Border Background="#B01E1F22"
                    Visibility="{Binding IsLoading, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                <TextBlock Text="Загрузка..." Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
            </Border>
            </Grid>
        </Grid>

        <!-- ================= СТАТУС-БАР ================= -->
        <Border Grid.Row="3" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="10,5" FontSize="12"/>
        </Border>

    </Grid>
</Window>
